---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

const posts = await getCollection("posts");
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latestPost = posts[0];
const olderPosts = posts.slice(1, 5);

const { Content } = latestPost ? await render(latestPost) : { Content: null };

function stripMarkdown(body: string): string {
  return body
    .replace(/^---[\s\S]*?---/, "")
    .replace(/!\[.*?\]\(.*?\)/g, "")
    .replace(/\[([^\]]+)\]\(.*?\)/g, "$1")
    .replace(/[#*>`_~]/g, "")
    .trim();
}

function getExcerpt(body: string): string {
  const plain = stripMarkdown(body);
  const match = plain.match(/[^.!?]*[.!?]/);
  return match ? match[0].trim() : plain.slice(0, 120);
}

function formatDate(date: Date): string {
  return date.toLocaleDateString("en-US", { month: "long", year: "numeric" });
}
---

<BaseLayout>
  <header class="intro">
    <img src="/avatar.png" alt="" class="avatar" transition:name="avatar" />
    <div class="intro-text">
      <h1 transition:name="intro-name">mircea</h1>
      <p class="tagline" transition:name="intro-tagline">still taking things apart</p>
    </div>
  </header>

  {latestPost && Content && (
    <article class="latest">
      <h2 class="latest-title"><a href={`/posts/${latestPost.id}/`} class="latest-title-link">{latestPost.data.title}</a></h2>
      <time class="latest-date" datetime={latestPost.data.date.toISOString()}>{formatDate(latestPost.data.date)}</time>
      <div class="latest-content">
        <Content />
      </div>
    </article>
  )}

  {olderPosts.length > 0 && (
    <section class="older">
      <h3 class="section-label">earlier</h3>
      <ul>
        {olderPosts.map((post) => (
          <li>
            <a href={`/posts/${post.id}/`}>
              <span class="post-title">{post.data.title}</span>
              <span class="post-excerpt">{getExcerpt(post.body ?? "")}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}
</BaseLayout>

<style>
  .intro {
    margin: 1rem 0 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--surface);
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .avatar {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .intro h1 {
    font-size: 1.2rem;
    margin-bottom: 0.05rem;
    line-height: 1.2;
  }

  .tagline {
    font-family: 'Fira Code', monospace;
    color: var(--text-muted);
    font-size: 0.72rem;
  }

  .latest {
    margin: 2rem 0 3rem;
  }

  .latest-title {
    font-size: 1.4rem;
    margin-bottom: 0.3rem;
  }

  .latest-title-link {
    color: var(--text-bright);
    text-decoration: none;
    transition: color 0.2s;
  }

  .latest-title-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .latest-title-link:active {
    animation: pulse 0.3s ease-out;
  }

  @keyframes pulse {
    0% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.7; transform: scale(0.98); }
    100% { opacity: 1; transform: scale(1); }
  }

  .latest-date {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .latest-content {
    font-size: 0.95rem;
    line-height: 1.8;
  }

  .latest-content :global(p) {
    margin-bottom: 1rem;
  }

  .section-label {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: lowercase;
    letter-spacing: 0.1em;
    font-weight: 400;
    margin-bottom: 1rem;
  }

  .older {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--surface);
  }

  ul {
    list-style: none;
  }

  li {
    margin-bottom: 0.8rem;
  }

  li a {
    display: block;
    padding: 0.4rem 0;
  }

  li a:hover {
    text-decoration: none;
  }

  li a:hover .post-title {
    color: var(--accent);
  }

  .post-title {
    display: block;
    font-family: var(--font-heading);
    color: var(--text-bright);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .post-excerpt {
    display: block;
    color: var(--text-muted);
    font-size: 0.78rem;
    margin-top: 0.15rem;
  }
</style>
